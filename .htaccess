RewriteEngine On

# Redirect old .php URLs to new extensionless URLs
Redirect 301 /retro-villa.php /retro-villas
Redirect 301 /neo-villa.php /neo-retro
Redirect 301 /viswa-villa.php /retro-viswa-lonavala
Redirect 301 /retro-villa /retro-villas
Redirect 301 /neo-villa /neo-retro
Redirect 301 /viswa-villa /retro-viswa-lonavala

# Remove .php extension from all URLs
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# Serve .php file internally when extensionless URL is requested
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]
